#include "Xresources.d/themes/oktwilight"

Xft.antialias: true
Xft.hinting: true
Xft.rgba: rgb
Xft.hintstyle: hintslight
Xft.lcdfilter: lcddefault
Xterm*utf8: true
XTerm.vt100.font: 7x13
XTerm.vt100.faceName: xft:Terminus:pixelsize=16:style=Regular
XTerm.vt100.metaSendsEscape: true
XTerm.vt100.backarrowKey: false
XTerm.vt100.selectToClipboard: true
XTerm.vt100.translations: #override \
    Shift Ctrl <Key> C: copy-selection(CLIPBOARD) \n\
    Shift Ctrl <Key> V: insert-selection(CLIPBOARD) \n\
    Shift<Btn1Down>: select-start() \n\
    Shift<Btn1Motion>: select-extend() \n\
    Shift<Btn1Up>: select-end(CLIPBOARD)
XTerm.ttyModes: erase ^?
XTerm.termName: xterm-256color
XTerm*boldMode: true
! XClock*foreground: #a89984
! XClock*background: #1d2021
XClock*geometry: 64x64-0+0
XClock*strftime:  %a %d, %H:%M
XClock.Clock.analog: true
XClock.Clock.update: 1
XClock.Clock.face: monospace:style=Italic:size=13
XClock.Clock.background:  #32302f
XClock.Clock.foreground:  #a89984
XClock.Clock.majorColor:  #a89984
XClock.Clock.minorColor:  #a89984
XClock.Clock.hourColor:   #a89984
XClock.Clock.minuteColor: #a89984
XClock.Clock.secondColor: #a89984
xosview*geometry: 64x64-1+64
xosview*font: 7x13
xosview*labels: false
xosview*background: #3f3f3f
xosview*foreground: #bebeb0
xosview*load: false
xosview*cpu: true
xosview*cpuFormat: single
xosview*cpuFreeColor: #2b2b2b
xosview*mem: true
xosview*memFreeColor: #2b2b2b
xosview*swap: false
xosview*page: false
xosview*gfx: false
xosview*NFSStats: false
xosview*NFSDStats: false
xosview*wireless: false
xosview*disk: false
xosview*battery: false
xosview*net: true
xosview*netBackground: #2b2b2b

