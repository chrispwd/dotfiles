#!/bin/sh

# ensures program executed once on startup
run_once() {
    if ! pgrep -f "$*" > /dev/null; then
        "$@" &
    fi
}

# manually run pulse
run_once pulseaudio --daemonize=no --exit-idle-time=-1

run_once pasystray

gpgconf --kill gpg-agent

eval "$(gpg-agent --homedir /home/chuddie/.gnupg --pinentry-program "$(which pinentry)" --daemon)"
